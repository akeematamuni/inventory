{
    "compileOnSave": false,
    "compilerOptions": {
        "rootDir": ".",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "node",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "importHelpers": true,
        "target": "es2015",
        "module": "esnext",
        "lib": ["es2020", "dom"],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@cloud-native-erp/core/decorators": [
                "libs/core/src/lib/decorators/index.ts"
            ],
            "@cloud-native-erp/core/domain": ["libs/core/src/lib/domain/index.ts"],
            "@cloud-native-erp/core/errors": ["libs/core/src/lib/errors/index.ts"],
            "@cloud-native-erp/core/guards": ["libs/core/src/lib/guards/index.ts"],
            "@cloud-native-erp/core/interceptors": ["libs/core/src/lib/interceptors/index.ts"],
            "@cloud-native-erp/core/logging": ["libs/core/src/lib/logging/index.ts"],
            "@cloud-native-erp/core/validation": ["libs/core/src/lib/validation/index.ts"],
            "@cloud-native-erp/core": ["libs/core/src/index.ts"],
        }
    },
    "exclude": ["node_modules", "tmp"]
}
